# Backend application
APP_NAME=RideGuard API
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://rideguard:rideguard@localhost:5432/rideguard

# Redis and Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_RESULT_EXPIRES=3600
CELERY_TASK_TIME_LIMIT_SECONDS=300
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=240

# Auth
SECRET_KEY=rideguard-dev-secret-change-me
TOKEN_ISSUER=rideguard-api
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Background work and cache TTLs
ENABLE_TRIGGER_MONITOR=true
REDIS_LOCK_TTL_SECONDS=120
RIDER_CACHE_TTL_SECONDS=300
ZONE_RISK_CACHE_TTL_SECONDS=300
ACTIVE_TRIGGER_CACHE_TTL_SECONDS=180

# Optional AI and ML model configuration
GEMINI_API_KEY=
# Leave model paths unset to use the repo defaults.
# DISRUPTION_MODEL_PATH=../models/disruption_model.pkl
# DISRUPTION_SCALER_PATH=../models/scaler.pkl
# FRAUD_MODEL_PATH=../models/fraud_model.pkl
# FRAUD_SCALER_PATH=../models/fraud_scaler.pkl
# FRAUD_SCORE_SCALER_PATH=../models/fraud_score_scaler.pkl
