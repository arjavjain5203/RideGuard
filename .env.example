# RideGuard local Docker defaults
#
# Service-specific samples live in:
# - backend/.env.example
# - frontend/.env.example
#
# docker-compose.yml provides development defaults directly for the local
# Postgres, Redis, backend, worker, and frontend services. Copy the service
# samples only when you need to run a service outside Docker Compose or override
# values for your local shell.

DATABASE_URL=postgresql://rideguard:rideguard@localhost:5432/rideguard
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

NEXT_PUBLIC_API_URL=http://localhost:8000/api
INTERNAL_API_URL=http://127.0.0.1:8000/api
